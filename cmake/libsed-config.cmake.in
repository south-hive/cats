@PACKAGE_INIT@

# libsed package config — generated by CMake.
#
# Propagates transitive dependencies so downstream consumers get them via
# find_package (no network fetch, suitable for closed-network builds).

include(CMakeFindDependencyMacro)

# Linux static linking pulls in pthread from libsed's static archive.
if(UNIX AND NOT APPLE)
    find_dependency(Threads)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/libsed-targets.cmake")

check_required_components(libsed)
